# Velocity Labs environment variables.
#
# Copy this file to .env.local for development or set these in the Vercel
# project settings for production. Every variable listed here is referenced
# somewhere in the app code; a missing REQUIRED value will break a feature
# at runtime (often silently), so don't skip any before deploying.
#
# Legend:
#   [R] required — the app will fail or silently misbehave without it
#   [O] optional — feature flag or fallback exists
#   [C] client-exposed — the NEXT_PUBLIC_ prefix ships this to the browser;
#                        never put a secret here.

# ─── Supabase ─────────────────────────────────────────────────────────────
# [R][C] Public Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=
# [R][C] Anon key. Safe to ship to the browser; RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# [R] Service role key. NEVER expose to the client. Used by API routes
#     and middleware to bypass RLS for owner-scoped queries.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (chatbot) ──────────────────────────────────────────────────
# [R] API key for Claude. Used by SMS/Instagram bots, demo chat, and the
#     dashboard AI assistant. Missing this disables all AI replies.
ANTHROPIC_API_KEY=

# ─── Stripe (payments) ────────────────────────────────────────────────────
# [R] Secret key. Used server-side to create checkout sessions.
STRIPE_SECRET_KEY=
# [R] Webhook signing secret from the Stripe dashboard. Verifies inbound
#     webhook authenticity; payment processing will reject events without it.
STRIPE_WEBHOOK_SECRET=

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────
# [R] Twilio account SID.
TWILIO_ACCOUNT_SID=
# [R] Twilio auth token. Used for outbound SMS and webhook signature check.
TWILIO_AUTH_TOKEN=
# [R] The phone number outbound SMS is sent FROM (e.g. +15551234567).
TWILIO_PHONE_NUMBER=
# [O] Override the webhook URL Twilio posts to. Defaults to the production
#     host. Only set for staging/preview environments.
TWILIO_WEBHOOK_URL=

# ─── Instagram / Meta ─────────────────────────────────────────────────────
# [O] Long-lived page access token (single-tenant fallback). Production
#     stores per-business tokens in the DB; this is only for local dev.
INSTAGRAM_ACCESS_TOKEN=
# [O] Instagram account ID paired with the access token above.
INSTAGRAM_ACCOUNT_ID=
# [R] App secret used to verify Meta webhook HMAC signatures.
INSTAGRAM_APP_SECRET=
# [R] Verify token configured in the Meta developer portal for the
#     webhook subscription handshake.
INSTAGRAM_VERIFY_TOKEN=
# [O] Meta app id, used for the OAuth callback flow.
META_APP_ID=
# [O] Meta app secret, used for the OAuth callback flow.
META_APP_SECRET=

# ─── Telegram ─────────────────────────────────────────────────────────────
# [O] Bot token from @BotFather, used by the Telegram assistant bridge.
TELEGRAM_BOT_TOKEN=
# [R if Telegram enabled] Random shared secret used to verify inbound
#     webhook POSTs from Telegram to our endpoint.
TELEGRAM_WEBHOOK_SECRET=
# [O][C] Bot username for deep-link generation in the dashboard.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# ─── Resend (transactional email) ─────────────────────────────────────────
# [R] API key for outbound transactional email.
RESEND_API_KEY=

# ─── Vercel (admin tooling) ───────────────────────────────────────────────
# [O] Personal access token used by the admin domain-management routes to
#     attach custom domains on behalf of tenants.
VERCEL_API_TOKEN=
# [O] Vercel project id paired with the token above.
VERCEL_PROJECT_ID=
# [O] Vercel team id for team-scoped API calls.
VERCEL_TEAM_ID=

# ─── App URLs ─────────────────────────────────────────────────────────────
# [R][C] Canonical production URL used for OpenGraph, sitemaps, and
#     server-to-server callbacks to our own API routes.
NEXT_PUBLIC_APP_URL=https://managevelocity.com
# [O][C] Alternate site URL for SEO metadata if different from APP_URL.
NEXT_PUBLIC_SITE_URL=https://managevelocity.com
# [O] Domain used for generating short payment links. Defaults to the app
#     domain if unset.
PAYMENT_LINK_DOMAIN=

# ─── Analytics ────────────────────────────────────────────────────────────
# [O][C] Google Analytics 4 measurement id. Analytics is skipped if unset.
NEXT_PUBLIC_GA_ID=

# ─── Access codes (legacy gating) ─────────────────────────────────────────
# [O] Comma-separated list of access codes accepted by /api/verify-access.
#     Prefer the database-backed flow; this is a backwards-compat fallback.
ACCESS_CODES=
# [O] Single access code. Same fallback behavior as ACCESS_CODES.
ACCESS_CODE=
# [O] Admin master access code that bypasses the per-code checks.
MASTER_ACCESS_CODE=
# [O] Password gate for the public demo page.
DEMO_PASSWORD=

# ─── Cron authentication ──────────────────────────────────────────────────
# [R for cron] Shared secret checked by /api/cron/* and /api/reactivation/cron/*
#     before executing scheduled work. Vercel sends this in the Authorization
#     header based on vercel.json. Any value ≥32 chars is fine.
CRON_SECRET=

# ─── Encryption at rest (LB-6) ────────────────────────────────────────────
# [R] Master key used by lib/crypto.ts to encrypt per-tenant Stripe secret
#     keys, Instagram long-lived access tokens, and similar secrets before
#     they are stored in Postgres. Rotating this key requires re-encrypting
#     every row that uses it — do not rotate casually.
# 32-byte hex, generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Admin session restore (LB-2) ────────────────────────────────────────
# [O] Kill switch for /api/admin/restore-session. The endpoint is a
#     "re-mint my own session" helper used after exiting impersonation and
#     is SELF-ONLY (caller must equal adminUserId). Default is off; set to
#     "true" only in environments where the impersonation flow is enabled.
ENABLE_SESSION_RESTORE=false

# ─── Shared rate limiter (LB-10) ─────────────────────────────────────────
# Rate limiting is backed by `lib/rate-limit.ts`. When BOTH of the vars
# below are set, the limiter talks to Upstash Redis via its REST API and
# becomes a shared store across every serverless instance. When either is
# unset, the limiter falls back to an in-process `Map` — this is fine for
# local dev but NOT safe for production: every Vercel cold start resets
# the counters and every parallel lambda gets its own bucket, which means
# OTP brute-force, bulk SMS abuse, and API flood limits are effectively
# off in practice.
# [O for dev / R for prod] Upstash Redis REST URL, e.g.
#     https://usw1-equipped-mule-12345.upstash.io
UPSTASH_REDIS_REST_URL=
# [O for dev / R for prod] Upstash Redis REST token. Create a read+write
#     token in the Upstash console.
UPSTASH_REDIS_REST_TOKEN=

# ─── Observability (optional, recommended for production) ────────────────
# [O] Sentry DSN. When set, @sentry/nextjs initializes and begins capturing
#     errors + performance traces. Leave empty to disable.
SENTRY_DSN=
# [O][C] Client-side Sentry DSN, shipped to the browser. Usually the same
#     DSN as SENTRY_DSN; split so you can disable one side independently.
NEXT_PUBLIC_SENTRY_DSN=
